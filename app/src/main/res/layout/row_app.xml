<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical"
    android:layoutDirection="rtl"
    android:minHeight="76dp"
    android:orientation="horizontal">

    <ImageView android:id="@+id/app_icon" android:layout_width="48dp" android:layout_height="48dp" android:contentDescription="@null" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="14dp" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/app_label" style="@style/Text.CardTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:textSize="17sp" />
        <TextView android:id="@+id/app_package" style="@style/Text.CardBody" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:ellipsize="middle" android:maxLines="1" android:textDirection="ltr" />
    </LinearLayout>
    <TextView android:id="@+id/app_check" android:layout_width="28dp" android:layout_height="28dp" android:gravity="center" android:text="✓" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" />
</LinearLayout>
