<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/session_background"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/session_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/session_header_subtitle"
                    android:textColor="@color/session_muted"
                    android:textSize="14sp" />
            </LinearLayout>

            <Button
                android:id="@+id/button_theme"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="@drawable/bg_session_outline"
                android:minWidth="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/session_theme_button"
                android:textAllCaps="false"
                android:textColor="@color/session_text"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_session_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/text_status_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/session_text"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_status_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:textColor="@color/session_muted"
                android:textSize="15sp" />

            <ProgressBar
                android:id="@+id/progress_session"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="18dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/session_primary"
                android:visibility="gone" />

            <Button
                android:id="@+id/button_primary"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_session_primary"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panel_devices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_session_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/session_nearby_devices_title"
                android:textColor="@color/session_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_devices_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:padding="18dp"
                android:text="@string/session_no_devices_yet"
                android:textColor="@color/session_muted"
                android:textSize="14sp" />

            <ListView
                android:id="@+id/list_devices"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginTop="10dp"
                android:divider="@android:color/transparent"
                android:dividerHeight="10dp"
                android:listSelector="@android:color/transparent"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panel_connected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_session_connected"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/session_connected_with"
                android:textColor="@color/session_success"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_connected_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/session_text"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/session_active_body"
                android:textColor="@color/session_muted"
                android:textSize="15sp" />

            <Button
                android:id="@+id/button_disconnect"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_session_outline"
                android:text="@string/session_disconnect"
                android:textAllCaps="false"
                android:textColor="@color/session_danger"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:text="@string/session_privacy_note"
            android:textColor="@color/session_muted"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
