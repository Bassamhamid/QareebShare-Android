<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <ImageButton
        android:id="@+id/button_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_brand_soft"
        android:contentDescription="@string/back"
        android:padding="12dp"
        android:src="@drawable/ic_back" />

    <TextView
        style="@style/Text.Title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/receive_title" />

    <TextView
        style="@style/Text.Subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/receive_subtitle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_brand_soft"
            android:contentDescription="@string/receive"
            android:padding="16dp"
            android:src="@drawable/ic_receive" />

        <ProgressBar
            android:id="@+id/progress_receive"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="18dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/text_receive_status"
            style="@style/Text.CardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="@string/receiver_not_started" />

        <TextView
            android:id="@+id/text_receive_peer"
            style="@style/Text.CardBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/no_connected_device" />

        <TextView
            android:id="@+id/button_start_receive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_primary_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/start_receiving"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/button_stop_receive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_secondary_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/stop_receiving"
            android:textColor="@color/brand_dark"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        style="@style/Text.CardBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="@string/receiver_privacy_note" />
</LinearLayout>
